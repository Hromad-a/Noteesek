# Optional superuser bootstrap for the PocketBase container.
# Copy to `.env` (same folder as docker-compose.yml) and fill in.
# On every container start, entrypoint.sh runs `superuser upsert` with these,
# creating the admin on a fresh pb_data or resetting its password otherwise.
# Leave unset / delete `.env` to manage the superuser manually via /_/.
#
# Password must be at least 8 characters.
PB_SUPERUSER_EMAIL=admin@noteesek.local
PB_SUPERUSER_PASSWORD=change-me-please

# --- SMTP (optional) ----------------------------------------------------------
# Set SMTP_HOST to enable outgoing mail (password-reset emails). Configured by
# server/pb_hooks/smtp.pb.js on every boot. Leave SMTP_HOST empty to disable.
#
# APP_URL is the public origin the reset email links back to (APP_URL/?reset=…).
# OPTIONAL: leave empty to auto-derive it from the request origin (works because
# the web app is served by this same server). No trailing slash.
#
# Set it explicitly only to override the auto-detection, e.g.:
#  - Behind a reverse proxy / HTTPS: if the proxy doesn't forward Host and
#    X-Forwarded-Proto/Host, the derived origin would be the internal address
#    (e.g. http://...:8080). Either pin APP_URL=https://your-domain here, or
#    configure PocketBase's Trusted proxy setting so the forwarded headers are
#    trusted and auto-detection yields the correct https://your-domain.
#  - To force a single canonical domain regardless of how users reach the app.
APP_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# false → STARTTLS (port 587, most providers). true → implicit TLS (port 465).
SMTP_TLS=false
# PLAIN (default) or LOGIN
SMTP_AUTH_METHOD=PLAIN
# Optional EHLO name; some relays (e.g. Gmail SMTP-relay) require it.
SMTP_LOCALNAME=
# Defaults to SMTP_USERNAME if left blank.
SMTP_SENDER_ADDRESS=
SMTP_SENDER_NAME=Noteesek
