# Keep the Docker build context small and fast.
.git
**/.DS_Store

# Flutter build artifacts / caches (regenerated inside the image)
app/build/
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/android/
app/ios/
app/**/*.g.dart
app/**/*.freezed.dart

# Server runtime data — never needed at build time
server/pb_data/
