# Copy to .env to override deploy defaults:  cp .env.example .env
#
# Image version to run. Use a published tag: a full version (0.2.0), a minor
# (0.2), a major (0), or `latest`. Pin an exact version for reproducible deploys.
NOTEESEK_VERSION=latest

# Host port the app, REST API, and admin dashboard are served on.
NOTEESEK_PORT=8090
