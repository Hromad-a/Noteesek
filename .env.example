# Copy to .env to configure your deployment:  cp .env.example .env
# Everything here is optional — without a .env, the defaults below apply and the
# admin is created manually via the /_/ dashboard.

# ── Deploy ────────────────────────────────────────────────────────────────────
# Image version to run. A full version (1.3.0), minor (1.3), major (1), or
# `latest`. Pin an exact version for reproducible deploys.
NOTEESEK_VERSION=latest

# Host port the app, REST API, and admin dashboard are served on.
NOTEESEK_PORT=8090

# ── Superuser bootstrap (optional) ────────────────────────────────────────────
# Set both to create/reset the PocketBase admin on every start (idempotent):
# created on a fresh pb_data, password reset otherwise. Leave unset to manage the
# admin manually via /_/. Password must be at least 8 characters.
PB_SUPERUSER_EMAIL=
PB_SUPERUSER_PASSWORD=

# ── SMTP (optional) ───────────────────────────────────────────────────────────
# Set SMTP_HOST to enable outgoing mail (password-reset emails). Applied by
# server/pb_hooks/smtp.pb.js on every boot. Leave SMTP_HOST empty to disable.
#
# APP_URL is the public origin reset emails link back to (APP_URL/?reset=…).
# Leave empty to auto-derive it from the request origin (works because the web
# app is served by this same server). Set it only to override, e.g. behind a
# reverse proxy / HTTPS that doesn't forward Host / X-Forwarded-* headers:
#   APP_URL=https://your-domain          (no trailing slash)
APP_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# false → STARTTLS (port 587, most providers). true → implicit TLS (port 465).
SMTP_TLS=false
# PLAIN (default) or LOGIN
SMTP_AUTH_METHOD=PLAIN
# Optional EHLO name; some relays (e.g. Gmail SMTP-relay) require it.
SMTP_LOCALNAME=
# Defaults to SMTP_USERNAME if left blank.
SMTP_SENDER_ADDRESS=
SMTP_SENDER_NAME=Noteesek
